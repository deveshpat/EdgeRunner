"""EdgeRunner Kaggle worker (generated — do not edit).

Pushed to Kaggle as a single script. Startup order is deliberate so the
frontend connects as fast as possible:

  1. pip install deps
  2. start the FastAPI app + cloudflared tunnel, print EDGERUNNER_URL=<url>
     → the browser connects here immediately (health/catalog work without a
       model; the picker shows the model as it loads)
  3. in the background: download the GGUF and start llama-server
     → chat goes live once llama is up

Blocks (supervising) until the API/tunnel exits or the watchdog hard-exits.

FILES is injected at build time; CONFIG is injected per launch. Both are JSON
parsed at runtime so JSON literals (true/false/null) stay valid.
"""
import base64, json, os, pathlib, re, subprocess, sys, threading, time, urllib.request

FILES = json.loads(r"""__FILES__""")
CONFIG = json.loads(r"""__CONFIG__""")
ROOT = pathlib.Path("/kaggle/working/edgerunner")

# Keep the kernel log tiny: Kaggle replays the whole log on every connect, so
# progress bars would bury EDGERUNNER_URL. hf_transfer (the Rust downloader) is
# left OFF — it could stall at 0 bytes without raising; plain hf_hub_download is
# reliable.
os.environ.setdefault("HF_HUB_DISABLE_PROGRESS_BARS", "1")
os.environ.setdefault("HF_HUB_DISABLE_TELEMETRY", "1")
os.environ.setdefault("HF_HUB_ENABLE_HF_TRANSFER", "0")

# Child processes to tear down on exit (llama is started from a worker thread).
PROCS = []


def log(m):
    print(f"[edgerunner] {m}", flush=True)


def materialize():
    for rel, b64 in FILES.items():
        p = ROOT / rel
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_bytes(base64.b64decode(b64))
    log(f"materialized {len(FILES)} files")


def pip(*args):
    subprocess.check_call([sys.executable, "-m", "pip", "install", "-q", *args])


# Prebuilt wheels live in this repo's release, so we never hit PyPI's slow
# llama-cpp-python sdist (compiles for minutes) or the flaky abetlen index. Each
# edgerunner-wheels-<pyver>-<accel>.tar.gz is a flat wheelhouse with the whole
# closure except two tiny pure-python server deps that pip fills from PyPI.
WHEELS_RELEASE = "https://github.com/deveshpat/EdgeRunner/releases/download/wheels-v1"
WHEELHOUSE = ROOT / "wheels"
_PKGS = ["llama-cpp-python[server]==0.3.33", "fastapi", "uvicorn[standard]",
         "httpx", "pydantic"]


def _fetch_wheelhouse():
    """Download+extract the wheelhouse matching this Python+accelerator.

    Returns the accelerator actually obtained ('gpu'/'cpu') or None.
    """
    import tarfile
    pyver = f"cp{sys.version_info.major}{sys.version_info.minor}"
    WHEELHOUSE.mkdir(parents=True, exist_ok=True)
    for accel in (["gpu", "cpu"] if CONFIG.get("gpu") else ["cpu"]):
        name = f"edgerunner-wheels-{pyver}-{accel}.tar.gz"
        tgz = ROOT / name
        try:
            log(f"fetching wheelhouse {name} …")
            urllib.request.urlretrieve(f"{WHEELS_RELEASE}/{name}", tgz)
            with tarfile.open(tgz) as t:
                t.extractall(WHEELHOUSE)
            log(f"wheelhouse ready ({accel})")
            return accel
        except Exception as e:
            log(f"  {name} unavailable ({e})")
    return None


def _install_from_index():
    """Fallback: PyPI for the pure-python deps + the abetlen prebuilt index for
    llama-cpp-python (never compiles). Used when no wheelhouse matches this
    Python, or the wheelhouse lacks a usable llama-cpp-python wheel."""
    pip("fastapi", "uvicorn[standard]", "httpx", "pydantic")
    variant = CONFIG.get("cuda", "cu124") if CONFIG.get("gpu") else "cpu"
    idx = f"https://abetlen.github.io/llama-cpp-python/whl/{variant}"
    pip("llama-cpp-python[server]", "--extra-index-url", idx,
        "--only-binary", "llama-cpp-python")


def install_deps():
    accel = _fetch_wheelhouse()
    if accel:
        try:
            # Wheelhouse first (offline for everything it has); pip reaches PyPI
            # only for the two small pure-python server deps. Never compile llama.
            pip("--find-links", str(WHEELHOUSE), "--only-binary",
                "llama-cpp-python", *_PKGS)
            CONFIG["_gpu_ok"] = accel == "gpu"
            log("deps installed")
            return
        except subprocess.CalledProcessError as e:
            # e.g. the gpu wheelhouse has no matching llama-cpp-python wheel.
            log(f"wheelhouse install failed ({e}); falling back to PyPI/abetlen")
    else:
        log("no prebuilt wheelhouse for this Python; falling back to PyPI/abetlen")
    _install_from_index()
    # The abetlen index resolves the accelerator by --extra-index-url variant,
    # so GPU stays GPU on the fallback path too.
    CONFIG["_gpu_ok"] = bool(CONFIG.get("gpu"))
    log("deps installed")


def start_api():
    env = dict(os.environ)
    env.update({
        "LLAMACPP_BASE_URL": "http://127.0.0.1:8080",
        "EDGERUNNER_WATCHDOG": "1",
        "EDGERUNNER_IDLE_TIMEOUT": str(CONFIG.get("idle_timeout", 90)),
        "EDGERUNNER_MAX_LIFETIME": str(CONFIG.get("max_lifetime", 3600)),
        "EDGERUNNER_STARTUP_GRACE": str(CONFIG.get("startup_grace", 90)),
        "PYTHONPATH": str(ROOT),
    })
    proc = subprocess.Popen(
        [sys.executable, "-m", "uvicorn", "app.main:app",
         "--host", "0.0.0.0", "--port", "8000"],
        cwd=str(ROOT), env=env,
        stdout=open(ROOT / "api.log", "w"), stderr=subprocess.STDOUT)
    PROCS.append(proc)
    for _ in range(60):
        try:
            urllib.request.urlopen("http://127.0.0.1:8000/api/health", timeout=2)
            log("api up")
            return proc
        except Exception:
            time.sleep(1)
    raise RuntimeError("FastAPI failed to start")


def _public_ok(url):
    """A real round-trip through the Cloudflare edge — the only proof the tunnel
    is usable (a 530 "unregistered" tunnel keeps its process alive and still
    prints a URL, so checking the process/log is not enough)."""
    try:
        req = urllib.request.Request(url.rstrip("/") + "/api/health",
                                     headers={"User-Agent": _UA})
        with urllib.request.urlopen(req, timeout=8) as r:
            return r.status == 200
    except Exception:
        return False


def start_tunnel():
    bin_path = ROOT / "cloudflared"
    if not bin_path.exists():
        urllib.request.urlretrieve(
            "https://github.com/cloudflare/cloudflared/releases/latest/download/"
            "cloudflared-linux-amd64", bin_path)
        bin_path.chmod(0o755)
    log_path = ROOT / "tunnel.log"
    # Force http2 (TCP): default QUIC (UDP :7844) is unreliable behind Kaggle's
    # NAT. Even so a quick tunnel occasionally comes up "born dead" — it prints a
    # URL but the edge never routes it (HTTP 530). So we verify the PUBLIC URL
    # actually answers before emitting it, and respawn if not. This is bounded
    # (max 3) and normally succeeds on the first try — no periodic reprint, no
    # protocol thrash. The keepalive() thread then holds it against idle-drop.
    for attempt in range(1, 4):
        proc = subprocess.Popen(
            [str(bin_path), "tunnel", "--no-autoupdate", "--protocol", "http2",
             "--url", "http://localhost:8000"],
            stdout=open(log_path, "w"), stderr=subprocess.STDOUT)
        url = None
        for _ in range(40):
            time.sleep(1)
            try:
                txt = log_path.read_text()
            except Exception:
                txt = ""
            m = re.search(r"https://[a-z0-9-]+\.trycloudflare\.com", txt)
            if m:
                url = m.group(0)
                break
        if url:
            # Wait up to ~30s for the edge to route it (fresh tunnels lag a few s).
            for _ in range(15):
                if _public_ok(url):
                    log(f"EDGERUNNER_URL={url}")
                    PROCS.append(proc)
                    return proc, url
                time.sleep(2)
            log(f"tunnel {url} came up unreachable (530); respawning (attempt {attempt})")
        else:
            log(f"cloudflared produced no URL; respawning (attempt {attempt})")
        try:
            proc.kill()
        except Exception:
            pass
    raise RuntimeError("cloudflared never produced a reachable tunnel")


# Download the GGUF with a plain HTTPS GET of the HF resolve URL, NOT
# huggingface_hub: on Kaggle, hf_hub_download's Xet transfer fails
# ("SignatureError: invalid key pair id") and stalls at 0 bytes, and anonymous
# downloads from Kaggle IPs are rate-limited to HTTP 403. A direct GET with an
# Authorization: Bearer <HF token> streams the full file in seconds.
_UA = ("Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
       "(KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36")


def download_model():
    repo, fname = CONFIG["model_repo"], CONFIG["model_file"]
    token = CONFIG.get("hf_token", "")
    dest = ROOT / fname
    url = f"https://huggingface.co/{repo}/resolve/main/{fname}?download=true"
    log(f"downloading {repo}/{fname} …")
    for attempt in range(1, 5):
        have = dest.stat().st_size if dest.exists() else 0
        headers = {"User-Agent": _UA, "Accept": "*/*"}
        if token:
            headers["Authorization"] = f"Bearer {token}"  # beats the anon 403
        if have:
            headers["Range"] = f"bytes={have}-"  # resume
        try:
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=30) as r:
                total = have + int(r.headers.get("Content-Length", 0) or 0)
                mode = "ab" if have and r.status == 206 else "wb"
                if mode == "wb":
                    have = 0
                last = time.time()
                with open(dest, mode) as f:
                    while True:
                        chunk = r.read(1 << 20)
                        if not chunk:
                            break
                        f.write(chunk)
                        have += len(chunk)
                        if time.time() - last >= 5:
                            pct = f" ({have * 100 // total}%)" if total else ""
                            log(f"  …downloaded {have // (1024 * 1024)} MB{pct}")
                            last = time.time()
            if dest.stat().st_size > 0 and (not total or dest.stat().st_size >= total):
                log(f"model downloaded ({dest.stat().st_size // (1024 * 1024)} MB)")
                return str(dest)
            log(f"download incomplete on attempt {attempt}; retrying")
        except Exception as e:
            log(f"download attempt {attempt} failed ({e}); retrying")
        time.sleep(3)
    raise RuntimeError("model download failed (set an HF token — anon is 403'd)")


def start_llama(model_path):
    # Alias so /v1/models reports a short id (not the full HF cache path).
    alias = CONFIG["model_file"].rsplit(".", 1)[0]
    proc = subprocess.Popen(
        [sys.executable, "-m", "llama_cpp.server",
         "--model", model_path, "--model_alias", alias,
         "--host", "127.0.0.1", "--port", "8080",
         "--n_ctx", str(CONFIG.get("n_ctx", 8192)),
         "--n_batch", "512",
         "--n_gpu_layers", "-1" if CONFIG.get("_gpu_ok", CONFIG.get("gpu")) else "0"],
        stdout=open(ROOT / "llama.log", "w"), stderr=subprocess.STDOUT,
        env=dict(os.environ))
    PROCS.append(proc)
    for _ in range(180):
        try:
            urllib.request.urlopen("http://127.0.0.1:8080/v1/models", timeout=2)
            log("llama server up — chat is live")
            return proc
        except Exception:
            time.sleep(2)
    raise RuntimeError("llama server failed to start")


def keepalive(url):
    """Ping the PUBLIC url every 15s so the tunnel never goes idle.

    cloudflared quick tunnels on Kaggle die from NAT idle-timeout: after ~30s
    with no traffic the connection is torn down and the quick-tunnel token can't
    re-register, so every later request returns HTTP 530. The browser heartbeats
    only every 25s (and not at all before it connects), which is too sparse to
    keep the path warm. This steady self-traffic keeps the edge connection alive
    independent of any client.
    """
    target = url.rstrip("/") + "/api/health"
    while True:
        time.sleep(15)
        try:
            urllib.request.urlopen(
                urllib.request.Request(target, headers={"User-Agent": _UA}),
                timeout=8)
        except Exception:
            pass


def load_model_in_background():
    try:
        start_llama(download_model())
    except Exception as e:
        log(f"model/llama setup failed: {e} (backend stays up; chat unavailable)")


def teardown():
    for p in PROCS:
        try:
            p.kill()
        except Exception:
            pass
    time.sleep(1)
    os._exit(0)


def main():
    materialize()
    install_deps()
    api = start_api()
    tunnel, url = start_tunnel()
    log(f"backend online at {url} — loading model in background")
    threading.Thread(target=keepalive, args=(url,), daemon=True).start()
    threading.Thread(target=load_model_in_background, daemon=True).start()

    # Supervise: the FastAPI watchdog os._exit()s its own process on idle/
    # shutdown, so when the API subprocess dies we tear everything down (else
    # the Kaggle session lingers and burns quota).
    try:
        while True:
            time.sleep(3)
            if api.poll() is not None:
                log("api exited — ending session")
                break
            if tunnel.poll() is not None:
                log("tunnel exited — ending session")
                break
    finally:
        teardown()


if __name__ == "__main__":
    main()
