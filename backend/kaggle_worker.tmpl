"""EdgeRunner Kaggle worker (generated — do not edit).

Pushed to Kaggle as a single script. Startup order is deliberate so the
frontend connects as fast as possible:

  1. pip install deps
  2. start the FastAPI app + cloudflared tunnel, print EDGERUNNER_URL=<url>
     → the browser connects here immediately (health/catalog work without a
       model; the picker shows the model as it loads)
  3. in the background: download the GGUF and start llama-server
     → chat goes live once llama is up

Blocks (supervising) until the API/tunnel exits or the watchdog hard-exits.

FILES is injected at build time; CONFIG is injected per launch. Both are JSON
parsed at runtime so JSON literals (true/false/null) stay valid.
"""
import base64, json, os, pathlib, re, subprocess, sys, threading, time, urllib.request

FILES = json.loads(r"""__FILES__""")
CONFIG = json.loads(r"""__CONFIG__""")
ROOT = pathlib.Path("/kaggle/working/edgerunner")

# Keep the kernel log tiny: Kaggle replays the whole log on every connect, so
# progress bars would bury EDGERUNNER_URL. hf_transfer (the Rust downloader) is
# left OFF — it could stall at 0 bytes without raising; plain hf_hub_download is
# reliable.
os.environ.setdefault("HF_HUB_DISABLE_PROGRESS_BARS", "1")
os.environ.setdefault("HF_HUB_DISABLE_TELEMETRY", "1")
os.environ.setdefault("HF_HUB_ENABLE_HF_TRANSFER", "0")

# Child processes to tear down on exit (llama is started from a worker thread).
PROCS = []


def log(m):
    print(f"[edgerunner] {m}", flush=True)


def materialize():
    for rel, b64 in FILES.items():
        p = ROOT / rel
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_bytes(base64.b64decode(b64))
    log(f"materialized {len(FILES)} files")


def pip(*args):
    subprocess.check_call([sys.executable, "-m", "pip", "install", "-q", *args])


def install_deps():
    pip("fastapi", "uvicorn[standard]", "httpx", "pydantic", "huggingface_hub")
    # llama-cpp-python ships prebuilt wheels ONLY via this index (PyPI is an
    # sdist that compiles from source). --only-binary fails fast if no wheel
    # matches instead of silently compiling for minutes.
    variant = CONFIG.get("cuda", "cu124") if CONFIG.get("gpu") else "cpu"
    idx = f"https://abetlen.github.io/llama-cpp-python/whl/{variant}"
    log(f"installing prebuilt llama-cpp-python wheel ({variant})")
    pip("llama-cpp-python[server]", "--extra-index-url", idx,
        "--only-binary", "llama-cpp-python")
    log("deps installed")


def start_api():
    env = dict(os.environ)
    env.update({
        "LLAMACPP_BASE_URL": "http://127.0.0.1:8080",
        "EDGERUNNER_WATCHDOG": "1",
        "EDGERUNNER_IDLE_TIMEOUT": str(CONFIG.get("idle_timeout", 90)),
        "EDGERUNNER_MAX_LIFETIME": str(CONFIG.get("max_lifetime", 3600)),
        "EDGERUNNER_STARTUP_GRACE": str(CONFIG.get("startup_grace", 90)),
        "PYTHONPATH": str(ROOT),
    })
    proc = subprocess.Popen(
        [sys.executable, "-m", "uvicorn", "app.main:app",
         "--host", "0.0.0.0", "--port", "8000"],
        cwd=str(ROOT), env=env,
        stdout=open(ROOT / "api.log", "w"), stderr=subprocess.STDOUT)
    PROCS.append(proc)
    for _ in range(60):
        try:
            urllib.request.urlopen("http://127.0.0.1:8000/api/health", timeout=2)
            log("api up")
            return proc
        except Exception:
            time.sleep(1)
    raise RuntimeError("FastAPI failed to start")


def start_tunnel():
    bin_path = ROOT / "cloudflared"
    if not bin_path.exists():
        urllib.request.urlretrieve(
            "https://github.com/cloudflare/cloudflared/releases/latest/download/"
            "cloudflared-linux-amd64", bin_path)
        bin_path.chmod(0o755)
    log_path = ROOT / "tunnel.log"
    proc = subprocess.Popen(
        [str(bin_path), "tunnel", "--no-autoupdate", "--url", "http://localhost:8000"],
        stdout=open(log_path, "w"), stderr=subprocess.STDOUT)
    PROCS.append(proc)
    for _ in range(40):
        time.sleep(1)
        try:
            txt = log_path.read_text()
        except Exception:
            txt = ""
        m = re.search(r"https://[a-z0-9-]+\.trycloudflare\.com", txt)
        if m:
            log(f"EDGERUNNER_URL={m.group(0)}")
            return proc, m.group(0)
    raise RuntimeError("cloudflared did not produce a URL")


def download_model():
    """Download the GGUF via huggingface_hub (reliable; retries on failure)."""
    from huggingface_hub import hf_hub_download

    repo, fname = CONFIG["model_repo"], CONFIG["model_file"]
    log(f"downloading {repo}/{fname} …")
    for attempt in range(1, 4):
        stop, t0 = threading.Event(), time.time()
        threading.Thread(
            target=lambda: [log(f"  …downloading {int(time.time()-t0)}s")
                            for _ in iter(lambda: stop.wait(15), True)],
            daemon=True).start()
        try:
            path = hf_hub_download(repo_id=repo, filename=fname)
            log(f"model downloaded in {int(time.time()-t0)}s")
            return path
        except Exception as e:
            log(f"download attempt {attempt} failed: {e}")
            time.sleep(5)
        finally:
            stop.set()
    raise RuntimeError("model download failed")


def start_llama(model_path):
    # Alias so /v1/models reports a short id (not the full HF cache path).
    alias = CONFIG["model_file"].rsplit(".", 1)[0]
    proc = subprocess.Popen(
        [sys.executable, "-m", "llama_cpp.server",
         "--model", model_path, "--model_alias", alias,
         "--host", "127.0.0.1", "--port", "8080",
         "--n_ctx", str(CONFIG.get("n_ctx", 8192)),
         "--n_batch", "512",
         "--n_gpu_layers", "-1" if CONFIG.get("gpu") else "0"],
        stdout=open(ROOT / "llama.log", "w"), stderr=subprocess.STDOUT,
        env=dict(os.environ))
    PROCS.append(proc)
    for _ in range(180):
        try:
            urllib.request.urlopen("http://127.0.0.1:8080/v1/models", timeout=2)
            log("llama server up — chat is live")
            return proc
        except Exception:
            time.sleep(2)
    raise RuntimeError("llama server failed to start")


def load_model_in_background():
    try:
        start_llama(download_model())
    except Exception as e:
        log(f"model/llama setup failed: {e} (backend stays up; chat unavailable)")


def teardown():
    for p in PROCS:
        try:
            p.kill()
        except Exception:
            pass
    time.sleep(1)
    os._exit(0)


def main():
    materialize()
    install_deps()
    api = start_api()
    tunnel, url = start_tunnel()
    log(f"backend online at {url} — loading model in background")
    threading.Thread(target=load_model_in_background, daemon=True).start()

    # Supervise: the FastAPI watchdog os._exit()s its own process on idle/
    # shutdown, so when the API subprocess dies we tear everything down (else
    # the Kaggle session lingers and burns quota).
    ticks = 0
    try:
        while True:
            time.sleep(3)
            ticks += 1
            if ticks % 7 == 0:  # re-emit URL so reconnects find it near the tail
                log(f"EDGERUNNER_URL={url}")
            if api.poll() is not None:
                log("api exited — ending session")
                break
            if tunnel.poll() is not None:
                log("tunnel exited — ending session")
                break
    finally:
        teardown()


if __name__ == "__main__":
    main()
